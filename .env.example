# Firebase Web (non-secret fields synced via: npm run firebase:sync-env-example)
# Add VITE_FIREBASE_API_KEY in .env locally (not committed).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=hidden-4f831.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=hidden-4f831
VITE_FIREBASE_STORAGE_BUCKET=hidden-4f831.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=723516874353
VITE_FIREBASE_APP_ID=1:723516874353:web:6fc83581bede4d0e7205d0

# Set to "true" when running Firebase Emulator Suite locally
VITE_USE_EMULATORS=false

# OpenAI (local dev image proxy uses OPENAI_API_KEY; Functions use secrets)
OPENAI_API_KEY=
# Optional; default is pinned snapshot gpt-image-2-2026-04-21
OPENAI_IMAGE_MODEL=gpt-image-2-2026-04-21
